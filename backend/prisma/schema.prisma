generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String              @unique @db.VarChar(150)
  passwordHash           String              @map("password_hash") @db.VarChar(255)
  rol                    Rol
  nombre                 String?             @db.VarChar(100)
  apellidos              String?             @db.VarChar(150)
  dni                    String?             @unique @db.VarChar(12)
  activo                 Boolean             @default(true)
  debeCambiarPassword    Boolean             @default(true) @map("debe_cambiar_password")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?           @map("deleted_at") @db.Timestamptz(6)
  alumno                 Alumno?
  apoderado              Apoderado?
  asistenciasRegistradas Asistencia[]        @relation("RegistradoPor")
  asistenciasJustificadas Asistencia[]       @relation("JustificadoPor")
  comunicadosPublicados  Comunicado[]        @relation("PublicadoPor")
  comunicadosEnvios      ComunicadoEnvio[]
  docente                Docente?
  recursosBiblioteca     RecursoBiblioteca[]
  // refreshTokens — tabla gestionada con $queryRaw/$executeRaw (prisma generate no disponible en este entorno)

  @@map("usuarios")
}

model Carrera {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre  String   @db.VarChar(100)
  area    Area
  activo  Boolean  @default(true)
  alumnos Alumno[]

  @@map("carreras")
}

model Alumno {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId       String            @unique @map("usuario_id") @db.Uuid
  dni             String            @unique @db.VarChar(12)
  nombre          String            @db.VarChar(100)
  apellidos       String            @db.VarChar(150)
  fechaNacimiento DateTime?         @map("fecha_nacimiento") @db.Date
  telefono        String?           @db.VarChar(20)
  codigoBarras    String            @unique @map("codigo_barras") @db.VarChar(6)
  fotoUrl         String?           @map("foto_url") @db.VarChar(500)
  aulaId          String?           @map("aula_id") @db.Uuid
  carreraId       String?           @map("carrera_id") @db.Uuid
  // Datos del formato oficial de matrícula (import por semestre)
  colegio           String?         @db.VarChar(150)
  quinto            Boolean?
  vecesMatriculado  Int?            @map("veces_matriculado")
  codigoInscripcion String?         @map("codigo_inscripcion") @db.VarChar(20)
  fechaMatricula    DateTime?       @map("fecha_matricula") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  aula            Aula?             @relation(fields: [aulaId], references: [id])
  carrera         Carrera?          @relation(fields: [carreraId], references: [id])
  usuario         Usuario           @relation(fields: [usuarioId], references: [id])
  apoderados      AlumnoApoderado[]
  asistencias     Asistencia[]
  pagos           Pago[]

  @@map("alumnos")
}

model Apoderado {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId        String            @unique @map("usuario_id") @db.Uuid
  nombre           String            @db.VarChar(100)
  apellidos        String            @db.VarChar(150)
  // El import por semestre crea apoderados con datos parciales: el CSV oficial
  // no trae DNI ni teléfono del apoderado, así que ambos son opcionales.
  dni              String?           @unique @db.VarChar(12)
  telefonoWhatsapp String?           @map("telefono_whatsapp") @db.VarChar(20)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  alumnos          AlumnoApoderado[]
  usuario          Usuario           @relation(fields: [usuarioId], references: [id])

  @@map("apoderados")
}

// Pagos / cuotas del alumno (del CSV oficial de matrícula). Gestionada por SQL
// manual (backend/prisma/manual/2026-07-import-semestre.sql); aquí solo para
// que Prisma Client genere los tipos.
model Pago {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alumnoId       String    @map("alumno_id") @db.Uuid
  tipoPago       String?   @map("tipo_pago") @db.VarChar(20)
  bancoTesoreria String?   @map("banco_tesoreria") @db.VarChar(20)
  codigoCuota    String?   @map("codigo_cuota") @db.VarChar(30)
  fechaCuota     DateTime? @map("fecha_cuota") @db.Date
  monto          Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  alumno         Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@index([alumnoId])
  @@map("pagos")
}

model AlumnoApoderado {
  alumnoId    String    @map("alumno_id") @db.Uuid
  apoderadoId String    @map("apoderado_id") @db.Uuid
  parentesco  String    @db.VarChar(50)
  esPrincipal Boolean   @default(false) @map("es_principal")
  alumno      Alumno    @relation(fields: [alumnoId], references: [id])
  apoderado   Apoderado @relation(fields: [apoderadoId], references: [id])

  @@id([alumnoId, apoderadoId])
  @@map("alumnos_apoderados")
}

model Docente {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId        String       @unique @map("usuario_id") @db.Uuid
  dni              String       @unique @db.VarChar(12)
  nombre           String       @db.VarChar(100)
  apellidos        String       @db.VarChar(150)
  especialidad     String?      @db.VarChar(100)
  telefonoWhatsapp String?      @map("telefono_whatsapp") @db.VarChar(20)
  fotoUrl          String?      @map("foto_url") @db.VarChar(500)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)
  asistencias      Asistencia[]
  usuario          Usuario      @relation(fields: [usuarioId], references: [id])
  horarios         Horario[]

  @@map("docentes")
}

model Ciclo {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String    @db.VarChar(100)
  fechaInicio DateTime  @map("fecha_inicio") @db.Date
  fechaFin    DateTime  @map("fecha_fin") @db.Date
  activo      Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  aulas       Aula[]

  @@map("ciclos")
}

model Aula {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cicloId    String       @map("ciclo_id") @db.Uuid
  nombre     String       @db.VarChar(20)
  turno      Turno
  area       Area
  cupoMaximo Int          @default(40) @map("cupo_maximo")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  alumnos    Alumno[]
  comunicados Comunicado[]
  horarios   Horario[]
  ciclo      Ciclo        @relation(fields: [cicloId], references: [id])

  // Un aula queda unívocamente identificada por ciclo + nombre + turno
  // (el import de alumnos indexa por nombre|turno dentro del ciclo activo).
  @@unique([cicloId, nombre, turno])
  @@map("aulas")
}

model TurnoConfig {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  turno             Turno    @unique
  horaEntrada       DateTime @map("hora_entrada") @db.Time(6)
  horaLimitePuntual DateTime @map("hora_limite_puntual") @db.Time(6)
  horaFin           DateTime @map("hora_fin") @db.Time(6)
  activo            Boolean  @default(true)

  @@map("turnos_config")
}

model Curso {
  id       String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre   String              @db.VarChar(100)
  codigo   String              @unique @db.VarChar(20)
  activo   Boolean             @default(true)
  horarios Horario[]
  recursos RecursoBiblioteca[]

  @@map("cursos")
}

model Horario {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aulaId     String   @map("aula_id") @db.Uuid
  cursoId    String   @map("curso_id") @db.Uuid
  docenteId  String   @map("docente_id") @db.Uuid
  diaSemana  Int      @map("dia_semana") @db.SmallInt
  horaInicio DateTime @map("hora_inicio") @db.Time(6)
  horaFin    DateTime @map("hora_fin") @db.Time(6)
  publicado  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  aula       Aula     @relation(fields: [aulaId], references: [id])
  curso      Curso    @relation(fields: [cursoId], references: [id])
  docente    Docente  @relation(fields: [docenteId], references: [id])

  @@map("horarios")
}

model Asistencia {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoPersona     TipoPersona @map("tipo_persona")
  alumnoId        String?     @map("alumno_id") @db.Uuid
  docenteId       String?     @map("docente_id") @db.Uuid
  fecha           DateTime    @db.Date
  horaIngreso     DateTime    @map("hora_ingreso") @db.Timestamptz(6)
  esTardanza         Boolean     @default(false) @map("es_tardanza")
  esManual           Boolean     @default(false) @map("es_manual")
  esAusente          Boolean     @default(false) @map("es_ausente")
  motivoManual       String?     @map("motivo_manual")
  justificacionRazon String?     @map("justificacion_razon")
  justificacionDoc   String?     @map("justificacion_doc")
  justificadoPorId   String?     @map("justificado_por") @db.Uuid
  justificadoEn      DateTime?   @map("justificado_en") @db.Timestamptz(6)
  registradoPorId    String      @map("registrado_por") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  alumno          Alumno?     @relation(fields: [alumnoId], references: [id])
  docente         Docente?    @relation(fields: [docenteId], references: [id])
  registradoPor   Usuario     @relation("RegistradoPor", fields: [registradoPorId], references: [id])
  justificadoPor  Usuario?    @relation("JustificadoPor", fields: [justificadoPorId], references: [id])

  // Un registro por persona por día (Postgres trata los NULL como distintos,
  // así que cada índice solo aplica a su tipo). Cierra la race del escaneo doble.
  @@unique([alumnoId, fecha])
  @@unique([docenteId, fecha])
  @@map("asistencias")
}

