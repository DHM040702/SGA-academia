model Comunicado {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo           String            @db.VarChar(200)
  cuerpo           String
  adjuntoUrl       String?           @map("adjunto_url") @db.VarChar(500)
  destinatarioTipo TipoDestinatario  @map("destinatario_tipo")
  aulaId           String?           @map("aula_id") @db.Uuid
  canalSistema     Boolean           @default(true) @map("canal_sistema")
  canalWhatsapp    Boolean           @default(false) @map("canal_whatsapp")
  publicadoPorId   String            @map("publicado_por") @db.Uuid
  publicadoAt      DateTime?         @map("publicado_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  aula             Aula?             @relation(fields: [aulaId], references: [id])
  publicadoPor     Usuario           @relation("PublicadoPor", fields: [publicadoPorId], references: [id])
  envios           ComunicadoEnvio[]

  @@map("comunicados")
}

model ComunicadoEnvio {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  comunicadoId String      @map("comunicado_id") @db.Uuid
  usuarioId    String      @map("usuario_id") @db.Uuid
  canal        CanalEnvio
  estado       EstadoEnvio @default(pendiente)
  enviadoAt    DateTime?   @map("enviado_at") @db.Timestamptz(6)
  leidoEn      DateTime?   @map("leido_en") @db.Timestamptz(6)
  errorDetalle String?     @map("error_detalle")
  comunicado   Comunicado  @relation(fields: [comunicadoId], references: [id])
  usuario      Usuario     @relation(fields: [usuarioId], references: [id])

  @@map("comunicados_envios")
}

model RecursoBiblioteca {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo      String      @db.VarChar(200)
  descripcion String?
  tipo        TipoRecurso
  url         String      @db.VarChar(500)
  cursoId     String?     @map("curso_id") @db.Uuid
  nivel       String?     @db.VarChar(50)
  area        Area?       // null = todas las áreas (filtro de envío)
  activo      Boolean     @default(true)
  descargas   Int         @default(0)
  subidoPorId String      @map("subido_por") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  curso       Curso?      @relation(fields: [cursoId], references: [id])
  subidoPor   Usuario     @relation(fields: [subidoPorId], references: [id])

  @@map("recursos_biblioteca")
}

model Auditoria {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId    String?  @map("usuario_id") @db.Uuid
  usuarioEmail String?  @map("usuario_email") @db.VarChar(150)
  usuarioRol   String?  @map("usuario_rol") @db.VarChar(20)
  accion       String   @db.VarChar(20) // crear | actualizar | eliminar | login | logout | login_fallido | reset_password | cambio_password
  entidad      String   @db.VarChar(50)
  entidadId    String?  @map("entidad_id") @db.VarChar(64)
  detalle      Json?
  ip           String?  @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([usuarioId])
  @@index([entidad])
  @@index([accion])
  @@map("auditoria")
}

enum Rol {
  admin
  director
  auxiliar
  alumno
  apoderado
  docente
}

enum Turno {
  manana
  tarde
}

enum Area {
  ciencias
  letras
  medicas
}

enum TipoPersona {
  alumno
  docente
}

enum TipoRecurso {
  pdf
  video
  enlace
  iframe
}

enum TipoDestinatario {
  todos
  seccion
  alumnos
  apoderados
  docentes
  usuario
}

enum CanalEnvio {
  whatsapp
  sms
  sistema
}

enum EstadoEnvio {
  pendiente
  enviado
  fallido
}
