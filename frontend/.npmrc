virtual-store-dir-max-length=120
# Hoistea los paquetes de ESLint al node_modules raíz para que el flat config
# (eslint.config.mjs) pueda importarlos con especificadores "pelados"
# (@eslint/eslintrc, eslint-config-next). Sin esto, pnpm los aísla y el import
# falla con ERR_MODULE_NOT_FOUND.
public-hoist-pattern[]=*eslint*

